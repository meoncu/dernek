rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function roles() {
      return signedIn() && request.auth.token.roles is list ? request.auth.token.roles : [];
    }

    function isAdmin() {
      return 'super_admin' in roles() || 'admin' in roles();
    }

    function canAccessTenant(tenantId) {
      return signedIn() && (tenantId in request.auth.token.tenantIds || isAdmin());
    }

    match /tenants/{tenantId}/users/{uid}/{allPaths=**} {
      allow read: if canAccessTenant(tenantId) && (request.auth.uid == uid || isAdmin());
      allow write: if canAccessTenant(tenantId) && (request.auth.uid == uid || isAdmin()) && request.resource.size < 20 * 1024 * 1024;
    }

    match /tenants/{tenantId}/projects/{projectId}/{allPaths=**} {
      allow read: if canAccessTenant(tenantId);
      allow write: if canAccessTenant(tenantId) && request.resource.size < 25 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
